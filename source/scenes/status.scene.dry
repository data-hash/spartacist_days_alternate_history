title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

[? if kpd_formed = 0 and nov_revolution = 0 : <h1><span style="color: var(--kpd_color)"><strong>Spartacus Group </span></strong>Leadership</h1> ?]
[? if kpd_formed = 0 and nov_revolution = 1 : <h1><span style="color: var(--kpd_color)"><strong>Spartacus League </span></strong>Leadership</h1> ?]
[? if kpd_formed = 1 and kpd_merge = 1 : <h1><span style="color: var(--kpd_color)"><strong>KPD </span></strong>Leadership</h1> ?]

<hr>

[? if party_leader == "Karl Liebknecht & Rosa Luxemburg": <div style="display: flex; gap: 5px; margin-top: 5px; margin-bottom: 5px; margin-left: -3px; justify-content: center;"> <img src="img/portraits/karl_liebknecht_portrait.jpg" alt="Karl Liebknecht" style="width: 45%; border: 5px solid var(--card-border-color);"> <img src="img/portraits/rosa_luxemburg_portrait.jpg" alt="Rosa Luxemburg" style="width: 45%; border: 5px solid var(--card-border-color);"> </div> ?]
[? if party_leader == "Karl Liebknecht & Rosa Luxemburg": <div style="display: flex;justify-content: left;"> <div style="text-align: center; width: 50%;"><strong>Karl Liebknecht</strong></div> <div style="text-align: center; width: 50%;"><strong>Rosa Luxemburg</strong></div> </div> ?]
[? if party_leader == "Karl Liebknecht & Rosa Luxemburg": <div style="display: flex;justify-content: left;"> <div style="text-align: center; width: 50%; color: var(--unavailable-color); font-size: 0.8em;"><em>Co-founder</em></div> <div style="text-align: center; width: 50%; color: var(--unavailable-color); font-size: 0.8em;"><em>Co-founder</em></div> </div> ?]

[? if kpd_formed = 0 and nov_revolution = 0 : Next congress: none scheduled?]
[? if nov_revolution = 1 : Next congress: December 1918?]

[? if uspd_formed = 0 and kpd_formed = 0 : Currently in: the <span style="color: var(--spd_color)"><strong>SPD</strong></span> ?]
[? if uspd_formed = 1 and kpd_formed = 0 : Currently in: the <span style="color: var(--uspd_color)"><strong>USPD</strong></span> ?]
[? if kpd_formed = 1 and kpd_merge = 0 : Currently in: the <span style="color: var(--kpd_color)"><strong>KPD</strong></span> ?]
# [? if kpd_formed = 1 and kpd_merge = 1 : Our position: we are the <span style="color: var(--kpd_color)"><strong>KPD</strong></span>! ?]

= Finances

Resources available: [+ resources +]

[? if kpd_in_government = 1 : Budget: [+ budget +] ?]

Grassroots support: [+ grassroots_support : support +]

Union backing: [+ union_support : support +]

Annual dues: [+ dues +]

# SPD position: [? if spd_toleration : toleration ?][? if spd_in_government : in government - ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 and burgfrieden == 0 : opposition ?][? if spd_caretaker : caretaker government ?][? if burgfrieden: political truce ?]
# [? if in_weimar_coalition and spd_in_government: Weimar Coalition ?][? if in_grand_coalition and spd_in_government: Grand Coalition ?][? if in_popular_front and spd_in_government: Popular Front ?][? if in_left_front and spd_in_government: Left Front ?][? if in_spd_majority and spd_in_government: SPD majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

# [? if spd_in_government and not in_spd_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

# [? if spd_in_government and (in_left_front or in_popular_front): KPD coalition dissent: [+ kpd_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

= Economics

Inflation: [+ inflation_2 +]%

[? if black_thursday_seen = 1 : Unemployment: [+ unemployed_2 +]% ?]

Economic growth: [+ economic_growth_2 +]%

# = Public Opinion

[? if kpd_formed = 1 and kpd_merge = 1 : <h1>Internal Factions of the <span style="color: var(--kpd_color)"><strong>KPD</span></strong></h1> ?]

[? if kpd_formed = 1 and kpd_merge = 1 : <span class="tooltip-text" data-tooltip="The Left wants to follow in the footsteps of the Bolsheviks, and seize power through revolution.">Left</span> strength: [+ left_strength : strength +], dissent: [+ left_dissent : dissent +] ?]

[? if kpd_formed = 1 and kpd_merge = 1 : <span class="tooltip-text" data-tooltip="The Center oppose the war, and wish to pursue an immediate peace.">Center</span> strength: [+ center_strength : strength +], dissent: [+ center_dissent : dissent +] ?]

[? if kpd_formed = 1 and kpd_merge = 1 : <span class="tooltip-text" data-tooltip="The Right (MSPD) support the war, however would like for it to end sooner rather than later.">Right</span> strength: [+ reformist_strength : strength +], dissent: [+ reformist_dissent : dissent +] ?]

[? if kpd_formed = 1 and kpd_merge = 1 : [? if neorevisionism > 0 : Neorevisionist strength: [+ neorevisionist_strength : strength +], dissent: [+ neorevisionist_dissent : dissent +] ?] ?]

@politics

= Inter-party Politics

[? if kpd_formed = 1 : <span class="tooltip-text" data-tooltip="Communist Party of Germany" style="color: var(--kpd_color);"><strong>KPD</strong></span> <br>Leader: [+ kpd_leader +] <br>Ideology: [+ kpd_ideology +]?]

[? if uspd_formed = 1 : <span class="tooltip-text" data-tooltip="Independent Social Democratic Party of Germany" style="color: var(--uspd_color);"><strong>USPD</strong></span> <br>Leader: [+ uspd_leader +] <br>Ideology: [+ uspd_ideology +]?]

[? if uspd_formed = 0 : <span class="tooltip-text" data-tooltip="Social Democratic Party of Germany" style="color: var(--spd_color);"><strong>SPD</strong></span> <br>Leader: [+ spd_leader +] <br>Ideology: [+ spd_ideology +] ?]
[? if uspd_formed = 1 and year < 1922 : <span class="tooltip-text" data-tooltip="Majority Social Democratic Party of Germany" style="color: var(--spd_color);"><strong>MSPD</strong></span> <br>Leader: [+ spd_leader +] <br>Ideology: [+ spd_ideology +] <br>Relations: [+ spd_relation : relationships +] ?]
[? if year > 1922 : <span class="tooltip-text" data-tooltip="Social Democratic Party of Germany" style="color: var(--spd_color);"><strong>SPD</strong></span> <br>Leader: [+ spd_leader +] <br>Ideology: [+ spd_ideology +] <br>Relations: [+ spd_relation : relationships +] ?]

[? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="Progressive People's Party" style="color: var(--ddp_color);"><strong>FVp</strong></span> <br>Leader: [+ ddp_leader +] <br>Ideology: [+ ddp_ideology +] <br>Relations: [+ ddp_relation : relationships +] ?]
[? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German Democratic Party" style="color: var(--ddp_color);"><strong>[+ ddp_name +]</strong></span> <br>Leader: [+ ddp_leader +] <br>Ideology: [+ ddp_ideology +] <br>Relations: [+ ddp_relation : relationships +] ?]

{!<span class="tooltip-text" data-tooltip="German Centre Party" style="color: var(--z_color);"><strong>Z</strong></span>!} <br>Leader: [+ z_leader +] <br>Ideology: [+ z_ideology +] <br>Relations: [+ z_relation : relationships +]

[? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="National Liberal Party" style="color: var(--dvp_color);"><strong>NLP</strong></span> <br>Leader: [+ dvp_leader +] <br>Ideology: [+ dvp_ideology +] <br>Relations: [+ dvp_relation : relationships +] ?]
[? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German People's Party" style="color: var(--dvp_color);"><strong>[+ dvp_name +]</strong></span>Leader: [+ dvp_leader +] <br>Ideology: [+ dvp_ideology +] <br>Relations: [+ dvp_relation : relationships +] ?]

[? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="German Conservative Party" style="color: var(--dnvp_color);"><strong>DKP</strong></span> <br>Leader: [+ dnvp_leader +] <br>Ideology: [+ dnvp_ideology +] <br>Relations: [+ dnvp_relation : relationships +] ?]
[? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German National People's Party" style="color: var(--dnvp_color);"><strong>[+ dnvp_name +]</strong></span> <br>Leader: [+ dnvp_leader +] <br>Ideology: [+ dnvp_ideology +] <br>Relations: [+ dnvp_relation : relationships +] ?]

[? if nsdap_formed: <span class="tooltip-text" data-tooltip="National-Socialist German Worker's Party (Nazis)" style="color: var(--nsdap_color);"><strong>NSDAP</strong></span> <br>Leader: [+ nsdap_leader +] <br>Ideology: [+ nsdap_ideology +] <br>Relations: [+ nsdap_relation : relationships +] ?]

# = Party Leadership

# <span class="tooltip-text" data-tooltip="Social Democratic Party of Germany" style="color: var(--spd_color);"><strong>SPD</strong></span>: [+ spd_ideology +] ([+ spd_leader +])

# [? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="Progressive People's Party" style="color: var(--ddp_color);"><strong>FVp</strong></span>: [+ ddp_ideology +] ([+ ddp_leader +]) ?]
# [? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German Democratic Party" style="color: var(--ddp_color);"><strong>[+ ddp_name +]</strong></span>: [+ ddp_ideology +] ([+ ddp_leader +]) ?]

# [? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="National Liberal Party" style="color: var(--dvp_color);"><strong>NLP</strong></span>: [+ dvp_ideology +] ([+ dvp_leader +]) ?]
# [? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German People's Party" style="color: var(--dvp_color);"><strong>[+ dvp_name +]</strong></span>: [+ dvp_ideology +] ([+ dvp_leader +]) ?]

# {!<span class="tooltip-text" data-tooltip="German Centre Party" style="color: var(--z_color);"><strong>Z</strong></span>!}: [+ spd_ideology +] ([+ spd_leader +])

# [? if nov_revolution = 1 : {!<span class="tooltip-text" data-tooltip="Bavarian People's Party" style="color: var(--bvp_color);"><strong>BVP</strong></span>!}: [+ bvp_ideology +] ([+ bvp_leader +]) ?]

# [? if nov_revolution = 0 : <span class="tooltip-text" data-tooltip="German Conservative Party" style="color: var(--dnvp_color);"><strong>DKP</strong></span>: [+ dnvp_ideology +] ([+ dnvp_leader +]) ?]
# [? if nov_revolution = 1 : <span class="tooltip-text" data-tooltip="German National People's Party" style="color: var(--dnvp_color);"><strong>[+ dnvp_name +]</strong></span>: [+ dnvp_ideology +] ([+ dnvp_leader +]) ?]

# [? if nsdap_formed: <span class="tooltip-text" data-tooltip="National-Socialist German Worker's Party (Nazis)" style="color: var(--nsdap_color);"><strong>NSDAP</strong></span>: [+ spd_ideology +] ([+ spd_leader +]) ?]

@paramilitaries
on-arrival: {!
if (Q.rb_strength) {
    Q.rb_strength_2 = Q.rb_strength.toFixed(1);
}
if (Q.rfb_strength) {
    Q.rfb_strength_2 = Q.rfb_strength.toFixed(1);
}
if (Q.sh_strength) {
    Q.sh_strength_2 = Q.sh_strength.toFixed(1);
}
if (Q.sa_strength) {
    Q.sa_strength_2 = Q.sa_strength.toFixed(1);
}
!}

= Paramilitaries

[? if reichsbanner_formed : <span class="tooltip-text" data-tooltip="The Reichsbanner Schwarz-Rot-Gold is a popular organization for defending democracy, mostly affiliated with the SPD.">Reichsbanner</span> Strength: [+ rb_strength_2 +] thousand?]

[? if reichsbanner_formed : Reichsbanner Militarization: [+ rb_militancy : militancy +]?]

[? if rfb_formed : <span class="tooltip-text" data-tooltip="The RFB (Rotfrontkämpferbund) is a communist group associated with the KPD.">RFB</span> Strength: [+ rfb_strength_2 +] thousand?]

[? if rfb_formed : RFB Militarization: [+ rfb_militancy : militancy +]?]

[? if stahlhelm_formed : <span class="tooltip-text" data-tooltip="The Stahlhelm is a right-wing organization of war veterans associated with the DNVP.">Stahlhelm</span> Strength: [+ sh_strength_2 +] thousand?]

[? if stahlhelm_formed : Stahlhelm Militarization: [+ sh_militancy : militancy +]?]

[? if sa_formed : <span class="tooltip-text" data-tooltip="The SA (Sturmabteilung) is the Nazi paramilitary.">SA</span> Strength: [+ sa_strength_2 +] thousand?]

[? if sa_formed : SA Militarization: [+ sa_militancy : militancy +]?]

[? if any_paramils_formed = 0: Currently no paramilitaries formed.?]

