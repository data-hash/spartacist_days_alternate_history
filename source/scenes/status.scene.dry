Workers: SPD: [+ workers_spd_display +]%, Z: [+ workers_z_display +]%, KPD: [+ workers_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ workers_ddp_display +]%, DVP: [+ workers_dvp_display +]%; DNVP: [+ workers_dnvp_display +]%, NSDAP: [+ workers_nsdap_display +]%, Others: [+ workers_other_display +]% [? if sapd_formed: SAPD: [+ workers_sapd_display +]% ?]

New Middle Class: SPD: [+ new_middle_spd_display +]%, Z: [+ new_middle_z_display +]%, KPD: [+ new_middle_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ new_middle_ddp_display +]%, DVP: [+ new_middle_dvp_display +]%; DNVP: [+ new_middle_dnvp_display +]%, NSDAP: [+ new_middle_nsdap_display +]%, Others: [+ new_middle_other_display +]% [? if sapd_formed: SAPD: [+ new_middle_sapd_display +]% ?]

Old Middle Class: SPD: [+ old_middle_spd_display +]%, Z: [+ old_middle_z_display +]%, KPD: [+ old_middle_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ old_middle_ddp_display +]%, DVP: [+ old_middle_dvp_display +]%; DNVP: [+ old_middle_dnvp_display +]%, NSDAP: [+ old_middle_nsdap_display +]%, Others: [+ old_middle_other_display +]% [? if sapd_formed: SAPD: [+ old_middle_sapd_display +]% ?]

Rural: SPD: [+ rural_spd_display +]%, Z: [+ rural_z_display +]%, KPD: [+ rural_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ rural_ddp_display +]%, DVP: [+ rural_dvp_display +]%; DNVP: [+ rural_dnvp_display +]%, NSDAP: [+ rural_nsdap_display +]%, Others: [+ rural_other_display +]% [? if sapd_formed: SAPD: [+ rural_sapd_display +]% ?]

Unemployed: SPD: [+ unemployed_spd_display +]%, Z: [+ unemployed_z_display +]%, KPD: [+ unemployed_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ unemployed_ddp_display +]%, DVP: [+ unemployed_dvp_display +]%; DNVP: [+ unemployed_dnvp_display +]%, NSDAP: [+ unemployed_nsdap_display +]%, Others: [+ unemployed_other_display +]% [? if sapd_formed: SAPD: [+ unemployed_sapd_display +]% ?]

Catholics: SPD: [+ catholics_spd_display +]%, Z: [+ catholics_z_display +]%, KPD: [+ catholics_kpd_display +]%, [? if not ddp_name: DDP?][? if ddp_name != 0 : [+ ddp_name +]?]: [+ catholics_ddp_display +]%, DVP: [+ catholics_dvp_display +]%; DNVP: [+ catholics_dnvp_display +]%, NSDAP: [+ catholics_nsdap_display +]%, Others: [+ catholics_other_display +]% [? if sapd_formed: SAPD: [+ catholics_sapd_display +]% ?]

@government

[? if president == "Wilhelm II" : <h1><span style="color: #000000">Imperial </span>Government</h1>?]

<hr>

[? if president == "Wilhelm II" : <div><img src="img/portraits/Wilhelm_II_portrait.jpg" alt="Wilhelm II" style="width: 50%; display: block; margin-top: 5px; margin: auto; margin-bottom: 5px; border: 5px solid var(--card-border-color);"></div> ?]
<div style="text-align: center;"><strong>[+ president +]</strong> (<span style="color: var(--president_party_color)"><strong>[+ president_party +]</strong></span>)</div>
[? if president == "Wilhelm II" : <div style="text-align: center; color: var(--unavailable-color); font-size: 0.8em;"><em>Emperor</em></div>?]
[? if nov_revolution = 1 : <div style="text-align: center; color: var(--unavailable-color); font-size: 0.8em;"><em>President</em></div>?]

= Cabinet

[? if chancellor == "Hollweg" : <div><img src="img/portraits/Bethmann_Hollweg_portrait.jpg" alt="Theobald von Bethmann Hollweg" style="width: 50%; display: block; margin-top: 5px; margin: auto; margin-bottom: 5px; border: 5px solid var(--card-border-color);"></div> ?]
<div style="text-align: center;"><strong>[+ chancellor +]</strong> (<span style="color: var(--chancellor_party_color)"><strong>[+ chancellor_party +]</span></strong>)</div>
<div style="text-align: center; color: var(--unavailable-color); font-size: 0.8em;"><em>Chancellor</em></div>

<div style="text-align: center;">Vice-chancellor: <br>[+ vice_chancellor +] (<span style="color: var(--vice_chancellor_party_color)"><strong>[+ vice_chancellor_party +]</span></strong>)</div>

[? if month = 2 and year = 1919 : <div style="text-align: center;">Minister of Labor: <br>[+ labor_minister +] (<span style="color: var(--labor_minister_party_color)"><strong>[+ labor_minister_party +]</strong></span>)</div> ?]

<div style="text-align: center;">Minister of the Interior: <br>[+ interior_minister +] (<span style="color: var(--interior_minister_party_color)"><strong>[+ interior_minister_party +]</strong></span>)</div>

<div style="text-align: center;">Minister of Finance: <br>[+ finance_minister +] (<span style="color: var(--finance_minister_party_color)"><strong>[+ finance_minister_party +]</strong></span>)</div>

[? if month = 10 and year = 1919 : <div style="text-align: center;">Minister of Economic: <br>[+ economic_minister +] (<span style="color: var(--economic_minister_party_color)"><strong>[+ economic_minister_party +]</strong></span>)</div> ?]

<div style="text-align: center;">Minister of Justice: <br>[+ justice_minister +] (<span style="color: var(--justice_minister_party_color)"><strong>[+ justice_minister_party +]</strong></span>)</div>

<div style="text-align: center;">Minister of Foreign Affairs: <br>[+ foreign_minister +] (<span style="color: var(--foreign_minister_party_color)"><strong>[+ foreign_minister_party +]</strong></span>)</div>

[? if nov_revolution = 0 : <div style="text-align: center;">Minister of War: <br>[+ reichswehr_minister +] (<span style="color: var(--reichswehr_minister_party_color)"><strong>[+ reichswehr_minister_party +]</strong></span>)</div> ?]
[? if nov_revolution = 1 : <div style="text-align: center;">Minister of Reichswehr: <br>[+ reichswehr_minister +] (<span style="color: var(--reichswehr_minister_party_color)"><strong>[+ reichswehr_minister_party +]</strong></span>)</div> ?]

<div style="text-align: center;">Minister of Agriculture: <br>[+ agriculture_minister +] (<span style="color: var(--agriculture_minister_party_color)"><strong>[+ agriculture_minister_party +]</strong></span>)</div>

@parliament
on-arrival: {!

Q.spd_seats = Math.round(Q.spd_r*5);
Q.uspd_seats = Math.round(Q.uspd_r*5);
Q.sapd_seats = Math.round(Q.sapd_r*5);
Q.kpd_seats = Math.round(Q.kpd_r*5);
Q.z_seats = Math.round(Q.z_r*5);
Q.bvp_seats = Math.round(Q.bvp_r*5);
Q.ddp_seats = Math.round(Q.ddp_r*5);
Q.other_seats = Math.round(Q.other_r*5);
Q.dvp_seats = Math.round(Q.dvp_r*5);
Q.dnvp_seats = Math.round(Q.dnvp_r*5);
Q.nsdap_seats = Math.round(Q.nsdap_r*5);

data = [
    {
        "id": "spd",
        "legend": "SPD",
        "name": "SPD",
        "seats": Math.round(Q.spd_r*5),
    }];
if (Q.sapd_formed && Q.sapd_r) {
    data.push({
            "id": "sapd",
            "legend": "SAPD",
            "name": "SAPD",
            "seats": Math.round(Q.sapd_r*5),
            });
}
if (Q.nsdap_formed && Q.nsdap_r) {
    data.push({
        "id": "nsdap",
        "legend": "NSDAP",
        "name": "NSDAP",
        "seats": Math.round(Q.nsdap_r*5),
    })
}
if (Q.kpd_formed && Q.kpd_r) {
    data.push({
        "id": "kpd",
        "legend": "KPD",
        "name": "KPD",
        "seats": Math.round(Q.kpd_r*5),
    })
}
if (Q.uspd_formed && Q.uspd_r) {
    data.push({
        "id": "uspd",
        "legend": "USPD",
        "name": "USPD",
        "seats": Math.round(Q.uspd_r*5),
    })
}
if (Q.nov_revolution == 1) {
    data.push({
        "id": "bvp",
        "legend": "BVP",
        "name": "BVP",
        "seats": Math.round(Q.bvp_r*5),
    })
}
data = data.concat([
    {
        "id": "ddp",
        "legend": Q.ddp_name,
        "name": Q.ddp_name,
        "seats": Math.round(Q.ddp_r*5),
    },
    {
        "id": "z",
        "legend": "Center",
        "name": "Center",
        "seats": Math.round(Q.z_r*5),
    },
    {
        "id": "dvp",
        "legend": Q.dvp_name,
        "name": Q.dvp_name,
        "seats": Math.round(Q.dvp_r*5),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_r*5),
    },
    {
        "id": "dnvp",
        "legend": Q.dnvp_name,
        "name": Q.dnvp_name,
        "seats": Math.round(Q.dnvp_r*5),
    },
]);

Q.parliament_data = data
!}
on-display: {!
data = Q.parliament_data;
if (d3 && window && Q.started) {
    var data = Q.parliament_data;
    var screenWidth = document.getElementById('qualities').offsetWidth;

    var width = Math.max(Math.min(screenWidth , 250), 120);
    var heightRatio = screenWidth < 350 ? 0.5 : 0.6;
    var height = width * heightRatio;

    document.getElementById("reichstag").style.height = height + "px";

    var reichstag_st = d3.parliament();
    reichstag_st.width(width)
    reichstag_st.height(height)
    reichstag_st.innerRadiusCoef(0.4)
    reichstag_st.enter.fromCenter(false).smallToBig(false)
    reichstag_st.exit.toCenter(false).bigToSmall(false);
    d3.select("#reichstag").datum(data).call(reichstag_st);
}
!}

<h1>Reichstag</h1>

<hr>

[? if president_reichstag == "Johannes Kaempf" : <div><img src="img/portraits/Johannes_Kaempf.jpg" alt="Johannes Kaempf" style="width: 50%;display: block;margin: auto;margin-top: 5px;margin-bottom: 5px;border: 5px solid var(--card-border-color);"></div> ?]
<div style="text-align: center;">**[+ president_reichstag +]** (<span style="color: var(--president_reichstag_color)"><strong>[+ president_reichstag_party +]</strong></span>)</div>
[? if nov_revolution = 0 and interim_government = 0 : <div style="text-align: center; color: var(--unavailable-color); font-size: 0.8em;"><em>President of the Reichstag</em></div> ?]
[? if nov_revolution = 1 and interim_government = 1 : <div style="text-align: center; color: var(--unavailable-color); font-size: 0.8em;"><em>President of the Weimar National Assembly</em></div> ?]

<div style="margin: auto;">{!<svg id="reichstag" style="width: 550px; height: 275px;"> </svg>!}</div>

{!<table>!}
{!<tr><td>Party</td><td>Seats</td><td>Status</td></tr>!}
# [? if kpd_formed = 1 : {!<tr><td><div class="box" style='background-color: var(--kpd_color); outline: 2px; outline-style: solid;'> </div> !} <strong>KPD:<strong> {!</td><td>!} <strong>[+ kpd_seats +]</strong> <strong>([+ kpd_r +]%)</strong> {!</td><td>!} [? if kpd_in_government = 0: <span style="color: #CC0000;">Opp.</span>?][? if kpd_in_government = 1: <span style="color: #009900;">Gov.</span>?] {!</td></tr>!} ?]

# [? if uspd_formed = 1 and kpd_formed = 0: {!<tr><td><div class="box" style='background-color: var(--uspd_color); outline: 2px; outline-style: solid;'> </div> !} <strong>USPD:<strong> {!</td><td>!} <strong>[+ uspd_seats +]</strong> <strong>([+ uspd_r +]%)</strong> {!</td><td>!} [? if uspd_in_government = 0: <span style="color: #CC0000;">Opp.</span>?][? if uspd_in_government = 1: <span style="color: #009900;">Gov.</span>?] {!</td></tr>!} ?]
