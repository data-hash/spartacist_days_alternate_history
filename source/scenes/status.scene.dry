# [? if nov_revolution = 1 : {!<tr><td><div class="box" style='background-color: var(--ddp_color);'> </div> !} <strong>DDP:<strong> {!</td><td>!} <strong>[+ ddp_seats +]</strong> ([+ ddp_r +]%) {!</td><td>!} [? if ddp_in_government = 0: <span style="color: #CC0000;">Opp.</span>?][? if ddp_in_government = 1: <span style="color: #009900;">Gov.</span>?] {!</td></tr>!} ?]

