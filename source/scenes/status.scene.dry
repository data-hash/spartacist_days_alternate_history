# 1928: 15, 1930: 15, 1932:
[? if nov_revolution = 0 : {!<span class="tooltip-text" title="German Centre Party" style="color:#000000"><strong>Z</strong></span>!}: [+ z_r +]%?]
[? if nov_revolution = 1 : {!<span class="tooltip-text" title="Center Party + Bavarian People's Party">{!<span style="color:#000000"><strong>Z</strong></span>!}+{!<span style="color:#A2D8E0">!}<strong>BVP</strong></span></span>!}: [+ z_r +]%?]
# 1928: 10, 1930: 13
[? if kpd_formed: {!<span class="tooltip-text" title="Communist Party of Germany" style="color:#700000"><strong>KPD</strong></span>!}: [+ kpd_r +]% ?]
# 1928: 5, 1930: 4 (as DstP)
[? if nov_revolution = 0 : {!<span class="tooltip-text" title="Progressive People's Party" style="color:#d4b402"><strong>FVp</strong></span>!}: [+ ddp_r +]%?]
[? if nov_revolution = 1 : {!<span class="tooltip-text" title="German Democratic Party" style="color:#FFCC00"><strong>[+ ddp_name +]</strong></span>!}: [+ ddp_r +]%?]
# 1928: 9, 1930: 5
[? if nov_revolution = 0 : {!<span class="tooltip-text" title="National Liberal Party" style="color:#98C22C"><strong>NLP</strong></span>!}: [+ dvp_r +]%?]
[? if nov_revolution = 1 : {!<span class="tooltip-text" title="German People's Party" style="color:#D3B454"><strong>[+ dvp_name +]</strong></span>!}: [+ dvp_r +]%?]
# 1928: 14, 1930: 7
[? if nov_revolution = 0 : {!<span class="tooltip-text" title="German Conservative Party" style="color:#0781E5"><strong>DKP</strong></span>!}: [+ dnvp_r +]%?]
[? if nov_revolution = 1 : {!<span class="tooltip-text" title="German National People's Party" style="color:#3F7BC1"><strong>[+ dnvp_name +]</strong></span>!}: [+ dnvp_r +]%?]
# 1928: 3, 1930: 18 [+ dnvp_r +]%
[? if nsdap_formed: {!<span class="tooltip-text" title="National-Socialist German Worker's Party (Nazis)" style="color:#964B00"><strong>NSDAP</strong></span>!}: [+ nsdap_r +]% ?]
# 1928: 9, 1930: 10
{!<span><strong>Others</strong></span>!}: [+ other_r +]%

[? if spd_in_government = 1 : Budget: [+ budget +] ?]

